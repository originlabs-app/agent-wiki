#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CONFIG_HOME="${HOME}/.agent-wiki/instances"
INSTANCE_NAME=""
CONFIG_PATH=""
CONFIG_FILE=""
INSTANCE_MODE="starter"
WIKI=""
RAW=""
LOG=""
INDEX=""
PROJECT_TEMPLATE=""
SOURCE_TEMPLATE=""
DECISION_TEMPLATE=""
OUTPUTS=""
declare -a SOURCE_DIRS=()
declare -a REMAINING_ARGS=()

today() {
  date +%F
}

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

unquote() {
  local value="$1"
  if [[ "$value" == \"*\" && "$value" == *\" ]]; then
    value="${value:1:${#value}-2}"
  elif [[ "$value" == \'*\' && "$value" == *\' ]]; then
    value="${value:1:${#value}-2}"
  fi
  printf '%s' "$value"
}

resolve_path_value() {
  local value="$1"
  local base_dir="${2:-$PWD}"
  case "$value" in
    "~") printf '%s\n' "$HOME" ;;
    "~"/*) printf '%s\n' "$HOME/${value#~/}" ;;
    /*) printf '%s\n' "$value" ;;
    *) printf '%s\n' "$base_dir/$value" ;;
  esac
}

absolutize_path() {
  local value="$1"
  case "$value" in
    /*) printf '%s\n' "$value" ;;
    ./*) printf '%s\n' "$PWD/${value#./}" ;;
    *) printf '%s\n' "$PWD/$value" ;;
  esac
}

set_storage_paths() {
  WIKI="$1"
  RAW="$2"
  OUTPUTS="$(dirname "$WIKI")/outputs"
  LOG="$WIKI/log.md"
  INDEX="$WIKI/index.md"
  PROJECT_TEMPLATE="$WIKI/projects/_template.md"
  SOURCE_TEMPLATE="$WIKI/sources/_template.md"
  DECISION_TEMPLATE="$WIKI/decisions/_template.md"
}

load_config_file() {
  local file="$1"
  local base_dir line key value entry
  local -a raw_dirs=()
  base_dir="$(cd "$(dirname "$file")" && pwd)"

  SOURCE_DIRS=()
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%%#*}"
    line="$(trim "$line")"
    [[ -z "$line" ]] && continue
    [[ "$line" == *=* ]] || continue

    key="$(trim "${line%%=*}")"
    value="$(trim "${line#*=}")"
    value="$(unquote "$value")"

    case "$key" in
      INSTANCE_NAME)
        [[ -n "$INSTANCE_NAME" ]] || INSTANCE_NAME="$value"
        ;;
      WIKI_ROOT)
        WIKI="$(resolve_path_value "$value" "$base_dir")"
        ;;
      RAW_ROOT)
        RAW="$(resolve_path_value "$value" "$base_dir")"
        ;;
      SOURCE_DIRS)
        IFS=':' read -r -a raw_dirs <<<"$value"
        SOURCE_DIRS=()
        for entry in "${raw_dirs[@]}"; do
          entry="$(trim "$entry")"
          [[ -n "$entry" ]] || continue
          SOURCE_DIRS+=("$(resolve_path_value "$entry" "$base_dir")")
        done
        ;;
    esac
  done <"$file"

  [[ -n "$WIKI" ]] || { echo "missing WIKI_ROOT in $file" >&2; exit 1; }
  [[ -n "$RAW" ]] || { echo "missing RAW_ROOT in $file" >&2; exit 1; }
}

configure_runtime() {
  local resolved_config=""
  INSTANCE_MODE="starter"
  SOURCE_DIRS=()
  set_storage_paths "$ROOT/wiki" "$ROOT/raw"

  if [[ -n "$CONFIG_PATH" ]]; then
    resolved_config="$(resolve_path_value "$CONFIG_PATH" "$PWD")"
  elif [[ -n "$INSTANCE_NAME" ]]; then
    resolved_config="$CONFIG_HOME/$INSTANCE_NAME.conf"
  fi

  if [[ -n "$resolved_config" ]]; then
    [[ -f "$resolved_config" ]] || {
      echo "missing instance config: $resolved_config" >&2
      exit 1
    }
    CONFIG_FILE="$resolved_config"
    WIKI=""
    RAW=""
    load_config_file "$resolved_config"
    set_storage_paths "$WIKI" "$RAW"
    INSTANCE_MODE="instance"
  else
    CONFIG_FILE=""
  fi
}

slugify() {
  printf '%s' "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | tr ' /' '--' \
    | sed -E 's/[^a-z0-9._-]+/-/g; s/-+/-/g; s/^-+//; s/-+$//'
}

project_file() {
  local project="$1"
  printf '%s/projects/%s.md' "$WIKI" "$(slugify "$project")"
}

relativize() {
  local path="$1"
  case "$path" in
    "$WIKI"/*) printf '%s\n' "wiki/${path#"$WIKI"/}" ;;
    "$RAW"/*) printf '%s\n' "raw/${path#"$RAW"/}" ;;
    "$ROOT"/*) printf '%s\n' "${path#"$ROOT"/}" ;;
    ./*) printf '%s\n' "${path#./}" ;;
    *) printf '%s\n' "$path" ;;
  esac
}

is_within_dir() {
  local path="$1"
  local dir="$2"
  case "$path" in
    "$dir"/*) return 0 ;;
    *) return 1 ;;
  esac
}

usage() {
  cat <<'EOF'
wikictl - local workflow helper

Usage:
  wikictl [--instance NAME | --config PATH] init
  wikictl [--instance NAME | --config PATH] status
  wikictl [--instance NAME | --config PATH] lint
  wikictl [--instance NAME | --config PATH] heal
  wikictl [--instance NAME | --config PATH] paths
  wikictl [--instance NAME | --config PATH] ingest <project> <source...>
  wikictl [--instance NAME | --config PATH] query <terms...>
  wikictl [--instance NAME | --config PATH] sync [agent op description...]
  wikictl [--instance NAME | --config PATH] log <agent> <op> <description...>
  wikictl init
  wikictl status
  wikictl lint
  wikictl heal
  wikictl paths
  wikictl ingest <project> <source...>
  wikictl query <terms...>
  wikictl sync [agent op description...]
  wikictl log <agent> <op> <description...>

Commands:
  init     Ensure the base directory structure exists.
  status   Show a short health summary.
  lint     Check that the core contract files exist and line up.
  heal     Rebuild the wiki index from project pages.
  paths    Show the resolved storage paths and mode.
  ingest   Register one or more source files against a project page.
  query    Search across wiki/ and raw/ for terms.
  sync     Optional end-of-session write-back plus lint/status.
  log      Append one entry to wiki/log.md.
EOF
}

ensure_dirs() {
  mkdir -p \
    "$WIKI/projects" \
    "$WIKI/sources" \
    "$WIKI/decisions" \
    "$RAW/untracked" \
    "$RAW/ingested" \
    "$OUTPUTS"
}

write_default_index() {
  cat >"$INDEX" <<'EOF'
---
type: wiki-index
updated: 2026-04-05
maintained-by: [agent-wiki]
---

# Wiki Index

Read this file first.

## Purpose

This is the compiled knowledge layer. Sources live in `raw/`, project-specific
summaries live in `wiki/projects/`, and the log records every meaningful
operation.

## How to use

- Start with the relevant project page.
- Expand to raw sources only when needed.
- Keep project summaries short and current.
- Write back after each meaningful session.

## Projects

| Project | Status | Updated | Wiki | Summary |
|--------|--------|---------|------|---------|

## References

- [[wiki/log]]
- [[wiki/projects/_template]]
- [[wiki/sources/_template]]
- [[wiki/decisions/_template]]
EOF
}

write_default_log() {
  cat >"$LOG" <<'EOF'
---
type: wiki-log
created: 2026-04-05
---

# Wiki Log

Append-only. One entry per operation.

Format:

```text
## [YYYY-MM-DD] agent | op | description
```
EOF
}

write_default_project_template() {
  cat >"$PROJECT_TEMPLATE" <<'EOF'
---
type: wiki-page
project: ProjectName
status: active
updated: 2026-04-05
updated_by: agent
repo: ""
---

# ProjectName — Overview

## Summary

One-paragraph summary.

## Current status

- What is happening now

## Decisions

- Important decisions with dates and sources

## What failed

- Failed attempts or dead ends

## Next steps

- [ ] Next action

## Sources

- [[path/to/source]]
EOF
}

write_default_source_template() {
  cat >"$SOURCE_TEMPLATE" <<'EOF'
---
type: wiki-source
source-type: article
title: ""
date: YYYY-MM-DD
project: ""
status: active
---

# Source Title

## Summary

One-paragraph source summary.

## Key facts

- Fact

## Contradictions with existing wiki

- None detected.
EOF
}

write_default_decision_template() {
  cat >"$DECISION_TEMPLATE" <<'EOF'
---
type: wiki-decision
decision: ""
date: YYYY-MM-DD
status: active
project: ""
---

# Decision Title

## Context

Why this decision was needed.

## Decision

What was decided.

## Consequences

- Outcome

## Sources

- [[wiki/projects/{project}]]
EOF
}

write_default_raw_readme() {
  cat >"$RAW/README.md" <<'EOF'
# Raw

Immutable source drop zone.

- Put new source material in `raw/untracked/`.
- Move processed source material to `raw/ingested/`.
- Do not edit files in place once they are considered source material.
- Compile the useful parts into `wiki/`.
EOF
}

write_default_outputs_readme() {
  cat >"$OUTPUTS/README.md" <<'EOF'
Generated answers, reports, and research live here.
EOF
}

ensure_files() {
  [[ -f "$INDEX" ]] || write_default_index
  [[ -f "$LOG" ]] || write_default_log
  [[ -f "$PROJECT_TEMPLATE" ]] || write_default_project_template
  [[ -f "$SOURCE_TEMPLATE" ]] || write_default_source_template
  [[ -f "$DECISION_TEMPLATE" ]] || write_default_decision_template
  [[ -f "$RAW/README.md" ]] || write_default_raw_readme
  [[ -f "$OUTPUTS/README.md" ]] || write_default_outputs_readme
}

frontmatter_value() {
  local file="$1"
  local key="$2"
  awk -v key="$key" '
    BEGIN { in_frontmatter = 0 }
    NR == 1 && $0 == "---" { in_frontmatter = 1; next }
    in_frontmatter && $0 == "---" { exit }
    in_frontmatter {
      if ($0 ~ "^" key ":") {
        sub("^" key ":[[:space:]]*", "", $0)
        gsub(/^"/, "", $0)
        gsub(/"$/, "", $0)
        print
        exit
      }
    }
  ' "$file"
}

set_frontmatter_value() {
  local file="$1"
  local key="$2"
  local value="$3"
  local tmp
  tmp="$(mktemp)"
  awk -v key="$key" -v value="$value" '
    BEGIN { in_frontmatter = 0; replaced = 0 }
    NR == 1 && $0 == "---" { in_frontmatter = 1; print; next }
    in_frontmatter && $0 == "---" {
      if (!replaced) print key ": " value
      print
      in_frontmatter = 0
      next
    }
    in_frontmatter {
      if ($0 ~ "^" key ":") {
        print key ": " value
        replaced = 1
        next
      }
    }
    { print }
  ' "$file" >"$tmp"
  mv "$tmp" "$file"
}

extract_summary() {
  local file="$1"
  local summary
  summary="$(
    awk '
      BEGIN { in_summary = 0; seen = 0 }
      /^## Summary$/ { in_summary = 1; next }
      in_summary && /^##[[:space:]]/ { exit }
      in_summary {
        if ($0 ~ /^[[:space:]]*$/) {
          if (seen) exit
          next
        }
        seen = 1
        print
      }
    ' "$file" | tr '\n' ' ' | sed -E 's/[[:space:]]+/ /g; s/^ //; s/ $//'
  )"
  if [[ -z "$summary" ]]; then
    summary="$(
      awk '
        BEGIN { in_body = 0; seen_heading = 0; seen_text = 0 }
        NR == 1 && $0 == "---" { in_frontmatter = 1; next }
        in_frontmatter && $0 == "---" { in_frontmatter = 0; next }
        in_frontmatter { next }
        /^# / { seen_heading = 1; next }
        seen_heading && /^##[[:space:]]/ { exit }
        seen_heading {
          if ($0 ~ /^[[:space:]]*$/) {
            if (seen_text) exit
            next
          }
          seen_text = 1
          print
        }
      ' "$file" | tr '\n' ' ' | sed -E 's/[[:space:]]+/ /g; s/^ //; s/ $//'
    )"
  fi
  if [[ -z "$summary" ]]; then
    summary="See page"
  fi
  printf '%s' "$summary"
}

append_log() {
  local agent="${1:?agent required}"
  local op="${2:?op required}"
  shift 2
  local description="${*:-}"
  ensure_dirs
  ensure_files
  {
    echo
    echo "## [$(today)] $agent | $op | $description"
  } >>"$LOG"
}

create_project_page() {
  local project="$1"
  local file="$2"
  local display_title="$project"
  cat >"$file" <<EOF
---
type: wiki-page
project: $project
status: active
updated: $(today)
updated_by: agent
repo: ""
---

# $display_title — Overview

## Summary

This page was created by \`wikictl ingest\`.

## Current status

- Needs synthesis.

## Decisions

- None yet.

## What failed

- None yet.

## Next steps

- [ ] Synthesize the ingested sources.

## Sources

EOF
}

ensure_project_page() {
  local project="$1"
  local file
  file="$(project_file "$project")"
  if [[ ! -f "$file" ]]; then
    create_project_page "$project" "$file"
    return
  fi
  set_frontmatter_value "$file" "type" "wiki-page"
  set_frontmatter_value "$file" "project" "$project"
  local status
  status="$(frontmatter_value "$file" status || true)"
  [[ -n "$status" ]] || status="active"
  set_frontmatter_value "$file" "status" "$status"
  set_frontmatter_value "$file" "updated" "$(today)"
  set_frontmatter_value "$file" "updated_by" "${WIKI_AGENT:-agent}"
  if [[ -z "$(frontmatter_value "$file" repo || true)" ]]; then
    set_frontmatter_value "$file" "repo" '""'
  fi
}

append_sources_to_project() {
  local file="$1"
  shift
  local source
  local added=0
  for source in "$@"; do
    local link
    link="$(relativize "$source")"
    if ! rg -Fq -- "- [[$link]]" "$file"; then
      if ! rg -q '^## Sources$' "$file"; then
        {
          echo
          echo "## Sources"
          echo
        } >>"$file"
      fi
      printf -- '- [[%s]]\n' "$link" >>"$file"
      added=1
    fi
  done
  return 0
}

move_source_to_ingested() {
  local source="$1"
  local untracked_root="$RAW/untracked"
  local ingested_root="$RAW/ingested"
  local rel target_dir target_base target ext candidate n

  if ! is_within_dir "$source" "$untracked_root"; then
    printf '%s\n' "$source"
    return 0
  fi

  rel="${source#"$untracked_root"/}"
  target="$ingested_root/$rel"
  target_dir="$(dirname "$target")"
  mkdir -p "$target_dir"

  if [[ ! -e "$target" ]]; then
    mv "$source" "$target"
    printf '%s\n' "$target"
    return 0
  fi

  if cmp -s "$source" "$target"; then
    rm -f "$source"
    printf '%s\n' "$target"
    return 0
  fi

  target_base="${target%.*}"
  ext=""
  if [[ "$target" == *.* ]]; then
    ext=".${target##*.}"
  fi

  n=2
  while true; do
    candidate="${target_base}-${n}${ext}"
    if [[ ! -e "$candidate" ]]; then
      mv "$source" "$candidate"
      printf '%s\n' "$candidate"
      return 0
    fi
    n=$((n + 1))
  done
}

rebuild_index() {
  ensure_dirs
  ensure_files
  local tmp file project status updated summary page_link
  tmp="$(mktemp)"
  {
    echo "---"
    echo "type: wiki-index"
    echo "updated: $(today)"
    echo "maintained-by: [agent-wiki]"
    echo "---"
    echo
    echo "# Wiki Index"
    echo
    echo "Read this file first."
    echo
    echo "## Purpose"
    echo
    echo "This is the compiled knowledge layer. Sources live in \`raw/\`, project-specific"
    echo "summaries live in \`wiki/projects/\`, and the log records every meaningful"
    echo "operation."
    echo
    echo "## How to use"
    echo
    echo "- Start with the relevant project page."
    echo "- Expand to raw sources only when needed."
    echo "- Keep project summaries short and current."
    echo "- Write back after each meaningful session."
    echo
    echo "## Projects"
    echo
    echo "| Project | Status | Updated | Wiki | Summary |"
    echo "|--------|--------|---------|------|---------|"

    while IFS= read -r file; do
      project="$(frontmatter_value "$file" project || true)"
      status="$(frontmatter_value "$file" status || true)"
      updated="$(frontmatter_value "$file" updated || true)"
      [[ -n "$project" ]] || project="$(basename "$file" .md)"
      [[ -n "$status" ]] || status="active"
      [[ -n "$updated" ]] || updated="$(today)"
      summary="$(extract_summary "$file")"
      summary="${summary//|/\\|}"
      page_link="[[wiki/projects/$(basename "$file" .md)]]"
      printf '| %s | %s | %s | %s | %s |\n' "$project" "$status" "$updated" "$page_link" "$summary"
    done < <(find "$WIKI/projects" -maxdepth 1 -name '*.md' ! -name '_template.md' | sort)

    echo
    echo "## References"
    echo
    echo "- [[wiki/log]]"
    echo "- [[wiki/projects/_template]]"
    echo "- [[wiki/sources/_template]]"
    echo "- [[wiki/decisions/_template]]"
  } >"$tmp"
  mv "$tmp" "$INDEX"
}

cmd_init() {
  ensure_dirs
  ensure_files
  echo "initialized: $WIKI"
}

cmd_status() {
  ensure_dirs
  local project_count raw_count stale_count
  project_count="$(find "$WIKI/projects" -maxdepth 1 -name '*.md' ! -name '_template.md' | wc -l | tr -d ' ')"
  raw_count="$(find "$RAW" -type f | wc -l | tr -d ' ')"
  stale_count="$(find "$WIKI/projects" -maxdepth 1 -name '*.md' ! -name '_template.md' -mtime +14 | wc -l | tr -d ' ')"
  echo "root: $ROOT"
  echo "wiki project pages: $project_count"
  echo "raw files: $raw_count"
  echo "stale project pages (>14d): $stale_count"
  echo "wiki root: $WIKI"
  echo "raw root: $RAW"
  echo "index: $INDEX"
  echo "log: $LOG"
}

cmd_lint() {
  ensure_dirs
  ensure_files
  local missing=0
  local path
  for path in \
    "$INDEX" \
    "$LOG" \
    "$PROJECT_TEMPLATE" \
    "$SOURCE_TEMPLATE" \
    "$DECISION_TEMPLATE" \
    "$OUTPUTS/README.md" \
    "$ROOT/SKILL.md" \
    "$ROOT/AGENTS.md" \
    "$ROOT/CLAUDE.md" \
    "$ROOT/README.md" \
    "$ROOT/INSTALL.md"; do
    if [[ ! -f "$path" ]]; then
      echo "missing: $path" >&2
      missing=1
    fi
  done

  if ! rg -q '^# Wiki Log$' "$LOG"; then
    echo "missing: wiki log header" >&2
    missing=1
  fi

  if rg -q '^## \[' "$LOG"; then
    :
  elif ! rg -q '^Format:$' "$LOG"; then
    echo "missing: log entry format" >&2
    missing=1
  fi

  local file stem field value
  while IFS= read -r file; do
    stem="$(basename "$file" .md)"
    [[ "$stem" == "_template" ]] && continue
    if ! rg -Fq "[[wiki/projects/$stem]]" "$INDEX"; then
      echo "missing: index entry for $stem" >&2
      missing=1
    fi
    for field in type project status updated updated_by; do
      value="$(frontmatter_value "$file" "$field" || true)"
      if [[ -z "$value" ]]; then
        echo "missing: $field in $file" >&2
        missing=1
      fi
    done
  done < <(find "$WIKI/projects" -maxdepth 1 -name '*.md' | sort)

  if [[ $missing -eq 0 ]]; then
    echo "lint: ok"
  else
    exit 1
  fi
}

cmd_heal() {
  ensure_dirs
  ensure_files
  rebuild_index
  append_log "system" "heal" "Rebuilt wiki index from project pages"
  echo "healed: index rebuilt"
}

cmd_ingest() {
  local project="${1:-}"
  shift || true
  if [[ -z "$project" || $# -lt 1 ]]; then
    echo "usage: wikictl ingest <project> <source...>" >&2
    exit 1
  fi

  ensure_dirs
  ensure_files

  local file source count=0 moved_source
  local -a resolved_sources=()
  file="$(project_file "$project")"
  ensure_project_page "$project"

  for source in "$@"; do
    source="$(absolutize_path "$source")"
    if [[ ! -e "$source" ]]; then
      echo "missing source: $source" >&2
      exit 1
    fi
    count=$((count + 1))
    moved_source="$(move_source_to_ingested "$source")"
    resolved_sources+=("$moved_source")
  done

  append_sources_to_project "$file" "${resolved_sources[@]}"
  set_frontmatter_value "$file" "updated" "$(today)"
  set_frontmatter_value "$file" "updated_by" "${WIKI_AGENT:-agent}"
  set_frontmatter_value "$file" "type" "wiki-page"
  set_frontmatter_value "$file" "project" "$project"
  append_log "${WIKI_AGENT:-agent}" "ingest" "$project | $count source(s)"
  rebuild_index
  echo "ingested: $project"
}

cmd_query() {
  ensure_dirs
  ensure_files
  local query="${*:-}"
  if [[ -z "$query" ]]; then
    echo "usage: wikictl query <terms...>" >&2
    exit 1
  fi

  local tmp hits term
  local -a patterns=()
  local -a rg_args=()
  tmp="$(mktemp)"
  hits=0
  patterns+=("$query")
  for term in "$@"; do
    [[ -n "$term" ]] || continue
    patterns+=("$term")
  done
  rg_args=(-n -i -C 2 -F --glob '*.md')
  for term in "${patterns[@]}"; do
    rg_args+=(-e "$term")
  done
  {
    echo "query: $query"
    echo
    echo "## wiki"
    if rg "${rg_args[@]}" "$WIKI" >"$tmp"; then
      cat "$tmp"
      hits=1
    else
      echo "No wiki matches."
    fi
    echo
    echo "## raw"
    if rg "${rg_args[@]}" "$RAW" >"$tmp"; then
      cat "$tmp"
      hits=1
    else
      echo "No raw matches."
    fi
  }
  rm -f "$tmp"

  append_log "${WIKI_AGENT:-agent}" "query" "$query"

  if [[ $hits -eq 0 ]]; then
    echo "No results."
  fi
}

cmd_sync() {
  if [[ $# -gt 0 ]]; then
    cmd_log "$@"
  else
    ensure_dirs
    ensure_files
  fi
  cmd_lint
  cmd_status
}

cmd_log() {
  local agent="${1:?agent required}"
  local op="${2:?op required}"
  shift 2
  local description="${*:-}"
  ensure_dirs
  ensure_files
  append_log "$agent" "$op" "$description"
  echo "logged: $agent | $op"
}

cmd_paths() {
  local joined_source_dirs=""
  if [[ ${#SOURCE_DIRS[@]} -gt 0 ]]; then
    joined_source_dirs="$(IFS=:; printf '%s' "${SOURCE_DIRS[*]}")"
  fi
  cat <<EOF
root=$ROOT
mode=$INSTANCE_MODE
instance_name=$INSTANCE_NAME
config_file=$CONFIG_FILE
wiki_root=$WIKI
raw_root=$RAW
index=$INDEX
log=$LOG
source_dirs=$joined_source_dirs
EOF
}

parse_global_options() {
  REMAINING_ARGS=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --instance)
        [[ $# -ge 2 ]] || { echo "--instance requires a name" >&2; exit 1; }
        INSTANCE_NAME="$2"
        shift 2
        ;;
      --config)
        [[ $# -ge 2 ]] || { echo "--config requires a path" >&2; exit 1; }
        CONFIG_PATH="$2"
        shift 2
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      --)
        shift
        break
        ;;
      *)
        break
        ;;
    esac
  done
  REMAINING_ARGS=("$@")
}

main() {
  local cmd=""
  parse_global_options "$@"
  configure_runtime

  cmd="${REMAINING_ARGS[0]:-}"
  case "$cmd" in
    init) cmd_init "${REMAINING_ARGS[@]:1}" ;;
    status) cmd_status "${REMAINING_ARGS[@]:1}" ;;
    lint) cmd_lint "${REMAINING_ARGS[@]:1}" ;;
    heal) cmd_heal "${REMAINING_ARGS[@]:1}" ;;
    paths) cmd_paths "${REMAINING_ARGS[@]:1}" ;;
    ingest) cmd_ingest "${REMAINING_ARGS[@]:1}" ;;
    query) cmd_query "${REMAINING_ARGS[@]:1}" ;;
    sync) cmd_sync "${REMAINING_ARGS[@]:1}" ;;
    log) cmd_log "${REMAINING_ARGS[@]:1}" ;;
    ""|help|-h|--help) usage ;;
    *)
      echo "unknown command: $cmd" >&2
      usage >&2
      exit 1
      ;;
  esac
}

main "$@"
